{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/idea_card",
  "title": "IdeaCard",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "idea_id", "title", "source_gap_ids", "source_claim_ids", "evidence_ids", "closest_work_ids", "generation_sources", "core_delta", "primary_claim", "mechanism", "why_now", "direct_baselines", "method_donors", "benchmark_opportunities", "estimated_compute", "estimated_timeline", "expected_failure_modes", "reviewer_attack_points", "strongest_rejection_case", "cheapest_falsification", "lineage", "roi", "duplicate_memory_matches", "readiness", "status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "idea_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "source_gap_ids": {"type": "array", "items": {"type": "string"}},
    "source_claim_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "closest_work_ids": {"type": "array", "items": {"type": "string"}},
    "generation_sources": {"type": "array", "minItems": 1, "items": {"type": "string", "enum": ["gap_driven", "reviewer_pressure_driven", "benchmark_blindspot_driven", "method_transfer_driven", "human_seed"]}},
    "core_delta": {"type": "string", "minLength": 1},
    "primary_claim": {"type": "string", "minLength": 1},
    "mechanism": {"type": "string", "minLength": 1},
    "why_now": {"type": "string", "minLength": 1},
    "direct_baselines": {"type": "array", "items": {"type": "string"}},
    "method_donors": {"type": "array", "items": {"type": "string"}},
    "benchmark_opportunities": {"type": "array", "items": {"type": "string"}},
    "estimated_compute": {"type": "string", "minLength": 1},
    "estimated_timeline": {"type": "string", "minLength": 1},
    "expected_failure_modes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "reviewer_attack_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["note_id", "objection_type", "severity", "summary"],
        "additionalProperties": false,
        "properties": {
          "note_id": {"type": "string"},
          "objection_type": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1}
        }
      }
    },
    "strongest_rejection_case": {"type": "string", "minLength": 1},
    "cheapest_falsification": {
      "type": "object",
      "required": ["claim_to_falsify", "minimal_test", "falsifies_if", "required_baseline_ids", "expected_cost"],
      "additionalProperties": false,
      "properties": {
        "claim_to_falsify": {"type": "string", "minLength": 1},
        "minimal_test": {"type": "string", "minLength": 1},
        "falsifies_if": {"type": "string", "minLength": 1},
        "required_baseline_ids": {"type": "array", "items": {"type": "string"}},
        "expected_cost": {"type": "string", "minLength": 1}
      }
    },
    "lineage": {
      "type": "object",
      "required": ["parent_gap_ids", "parent_idea_ids", "mutation_operator", "mutation_reason", "status"],
      "additionalProperties": false,
      "properties": {
        "parent_gap_ids": {"type": "array", "items": {"type": "string"}},
        "parent_idea_ids": {"type": "array", "items": {"type": "string"}},
        "mutation_operator": {"type": "string", "minLength": 1},
        "mutation_reason": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["reject", "refine", "proceed"]}
      }
    },
    "roi": {
      "type": "object",
      "required": ["positive_signals", "difficulty_signals", "unknowns", "reviewer_blockers", "confidence"],
      "additionalProperties": false,
      "properties": {
        "positive_signals": {"type": "object"},
        "difficulty_signals": {"type": "object"},
        "unknowns": {"type": "array", "items": {"type": "object"}},
        "reviewer_blockers": {"type": "array", "items": {"type": "object"}},
        "confidence": {"type": "string", "minLength": 1}
      }
    },
    "duplicate_memory_matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["memory_id", "subject_id", "reason", "similarity"],
        "additionalProperties": false,
        "properties": {
          "memory_id": {"type": "string"},
          "subject_id": {"type": "string"},
          "reason": {"type": "string"},
          "similarity": {"type": "number"}
        }
      }
    },
    "readiness": {
      "type": "object",
      "required": ["phase6_review_ready", "experiment_blueprint_ready", "not_ready_reasons"],
      "additionalProperties": false,
      "properties": {
        "phase6_review_ready": {"type": "boolean"},
        "experiment_blueprint_ready": {"type": "boolean"},
        "not_ready_reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "status": {"type": "string", "enum": ["phase6_ready", "not_ready_for_phase6", "not_ready_for_experiment", "speculative", "insufficient_evidence", "duplicate_risk"]}
  }
}
