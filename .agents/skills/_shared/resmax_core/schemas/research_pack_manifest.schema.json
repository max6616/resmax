{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/research_pack_manifest",
  "title": "ResearchPackManifest",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "pack_id", "research_spec_id", "artifacts", "decision_status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "pack_id": {"type": "string", "minLength": 1},
    "research_spec_id": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "research_spec",
              "source_policy",
              "query_family",
              "retrieval_trace",
              "selected_subdirection",
              "broad_candidates",
              "evidence_span",
              "evidence_card",
              "claim_graph",
              "gap_map",
              "missing_source_report",
              "missing_pdf_report",
              "coverage_report",
              "field_map",
              "source_materialization_report",
              "reviewer_pressure_notes",
              "paper_roles",
              "baseline_matrix",
              "benchmark_matrix",
              "implementation_matrix",
              "gap_roi_table",
              "roi_lens",
              "risk_register",
              "idea_seed_constraints"
            ]
          },
          "path": {"type": "string", "minLength": 1},
          "schema": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "artifact_count": {"type": "integer", "minimum": 1},
    "source_counts": {
      "type": "object",
      "additionalProperties": {"type": ["integer", "number", "boolean", "string"]}
    },
    "mechanical_checks": {
      "type": "object",
      "additionalProperties": {"type": ["boolean", "string", "integer", "number"]}
    },
    "evidence_coverage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selected_candidate_count": {"type": "integer", "minimum": 0},
        "papers_with_evidence": {"type": "integer", "minimum": 0},
        "evidence_span_count": {"type": "integer", "minimum": 0},
        "evidence_card_count": {"type": "integer", "minimum": 0},
        "missing_source_count": {"type": "integer", "minimum": 0},
        "missing_pdf_count": {"type": "integer", "minimum": 0},
        "abstract_fallback_count": {"type": "integer", "minimum": 0},
        "full_text_evidence_count": {"type": "integer", "minimum": 0}
      }
    },
    "source_materialization": {
      "type": "object",
      "additionalProperties": {"type": ["integer", "number", "boolean", "string"]}
    },
    "decision_status": {"type": "string", "enum": ["unknown", "pending", "promoted", "rejected", "needs_revision", "killed", "not_applicable"]}
  }
}
