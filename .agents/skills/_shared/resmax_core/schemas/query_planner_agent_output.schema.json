{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/query_planner_agent_output",
  "title": "QueryPlannerAgentOutput",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "raw_intent", "query_families"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "raw_intent": {"type": "string", "minLength": 1},
    "query_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["family_role", "information_need", "retrieval_mode", "filters", "queries"],
        "additionalProperties": false,
        "properties": {
          "family_role": {"type": "string", "enum": ["direct_baseline", "method_donor", "benchmark_opportunity", "implementation_reference", "negative_evidence", "reviewer_risk", "survey_or_taxonomy"]},
          "information_need": {"type": "string", "minLength": 1},
          "retrieval_mode": {"type": "string", "enum": ["hybrid"]},
          "filters": {"type": "object"},
          "queries": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["query_id", "semantic_text", "keyword_query", "query_type", "generation_reason"],
              "additionalProperties": false,
              "properties": {
                "query_id": {"type": "string", "minLength": 1},
                "semantic_text": {"type": "string", "minLength": 1},
                "keyword_query": {
                  "type": "object",
                  "required": ["required_concepts", "boost_phrases"],
                  "additionalProperties": false,
                  "properties": {
                    "required_concepts": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "array",
                        "minItems": 1,
                        "items": {"type": "string", "minLength": 1}
                      }
                    },
                    "boost_phrases": {
                      "type": "array",
                      "minItems": 1,
                      "items": {"type": "string", "minLength": 1}
                    },
                    "optional_terms": {
                      "type": "array",
                      "items": {"type": "string", "minLength": 1}
                    }
                  }
                },
                "query_type": {"type": "string", "enum": ["semantic_and_keyword"]},
                "generation_reason": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  }
}
