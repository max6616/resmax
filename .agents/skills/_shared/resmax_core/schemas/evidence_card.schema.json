{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/evidence_card",
  "title": "EvidenceCard",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "claim_text", "interpretation", "evidence_span_ids", "evidence_status", "source_weight", "limitations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "claim_text": {"type": "string", "minLength": 1},
    "interpretation": {"type": "string", "minLength": 1},
    "evidence_span_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_status": {"type": "string", "enum": ["unknown", "not_found", "not_applicable", "insufficient_evidence", "supported", "contradicted", "mixed"]},
    "source_weight": {"type": "string", "enum": ["unknown", "not_applicable", "primary", "secondary", "tertiary", "weak"]},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "relation": {"type": "string", "enum": ["supports", "contradicts", "extends", "narrows", "motivates", "context"]},
    "scope": {"type": "string"},
    "strength": {"type": "string", "enum": ["strong", "weak", "context"]}
  }
}
