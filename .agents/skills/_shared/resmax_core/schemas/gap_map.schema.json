{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/gap_map",
  "title": "GapMap",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "claim_graph_id", "gaps"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "claim_graph_id": {"type": "string", "minLength": 1},
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gap_id", "description", "gap_type", "supporting_claim_ids", "evidence_status", "roi_signals"],
        "additionalProperties": false,
        "properties": {
          "gap_id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "scope": {"type": "string"},
          "gap_type": {"type": "string", "enum": ["contradiction", "missing_evidence", "benchmark_blind_spot", "method_transfer", "reviewer_pressure", "resource_arbitrage", "evidence_tension", "closest_work_delta", "temporal_action_coherence", "feedforward_native_gaussian_editing", "large_magnitude_editing", "benchmark_protocol_gap"]},
          "supporting_claim_ids": {"type": "array", "items": {"type": "string"}},
          "evidence_card_ids": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "string", "enum": ["unknown", "low", "medium", "high"]},
          "evidence_status": {"type": "string", "enum": ["unknown", "not_found", "not_applicable", "insufficient_evidence", "supported", "contradicted", "mixed"]},
          "roi_signals": {
            "type": "object",
            "required": ["positive", "difficulty", "unknowns", "reviewer_blockers"],
            "additionalProperties": false,
            "properties": {
              "positive": {"type": "array", "items": {"type": "string"}},
              "difficulty": {"type": "array", "items": {"type": "string"}},
              "unknowns": {"type": "array", "items": {"type": "string"}},
              "reviewer_blockers": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
