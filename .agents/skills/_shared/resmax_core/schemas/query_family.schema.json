{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/query_family",
  "title": "QueryFamily",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "research_spec_id", "family_role", "information_need", "queries", "evidence_status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "research_spec_id": {"type": "string", "minLength": 1},
    "family_role": {"type": "string", "enum": ["direct_baseline", "method_donor", "benchmark_opportunity", "implementation_reference", "negative_evidence", "reviewer_risk", "survey_or_taxonomy"]},
    "information_need": {"type": "string", "minLength": 1},
    "retrieval_mode": {"type": "string", "enum": ["keyword", "embedding", "hybrid", "review_cache", "metadata"]},
    "filters": {"type": "object"},
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["query_id", "text", "query_type", "intent"],
        "additionalProperties": false,
        "properties": {
          "query_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "query_type": {"type": "string", "enum": ["keyword", "semantic", "citation", "review_cache", "metadata"]},
          "intent": {"type": "string", "minLength": 1}
        }
      }
    },
    "evidence_status": {"type": "string", "enum": ["unknown", "not_found", "not_applicable", "insufficient_evidence", "supported", "contradicted", "mixed"]}
  }
}
