{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/negative_memory",
  "title": "NegativeMemory",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "memory_id", "subject_id", "subject_type", "reason", "evidence_status", "evidence_card_ids", "decision_status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {"type": "object", "required": ["name"], "additionalProperties": false, "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string"}, "run_id": {"type": "string"}}},
    "memory_id": {"type": "string", "minLength": 1},
    "subject_id": {"type": "string", "minLength": 1},
    "subject_type": {"type": "string", "enum": ["gap", "idea", "claim", "experiment"]},
    "reason": {"type": "string", "minLength": 1},
    "evidence_status": {"type": "string", "enum": ["unknown", "not_found", "not_applicable", "insufficient_evidence", "supported", "contradicted", "mixed"]},
    "evidence_card_ids": {"type": "array", "items": {"type": "string"}},
    "decision_status": {"type": "string", "enum": ["unknown", "pending", "promoted", "rejected", "needs_revision", "killed", "not_applicable"]},
    "dedupe_key": {"type": "string", "minLength": 1},
    "reason_type": {"type": "string", "minLength": 1},
    "source_review_ids": {"type": "array", "items": {"type": "string"}},
    "source_gap_ids": {"type": "array", "items": {"type": "string"}},
    "supersedes_memory_id": {"type": "string"}
  }
}
