{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/source_policy",
  "title": "SourcePolicy",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "research_spec_id", "allowed_source_tiers", "allowed_retrieval_modes", "disallowed_sources", "disabled_capabilities", "claim_support_policy", "evidence_defaults"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string"},
        "run_id": {"type": "string"}
      }
    },
    "research_spec_id": {"type": "string", "minLength": 1},
    "allowed_source_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["full_text", "landing_only", "listing_only", "metadata_plus_aux", "metadata_only", "not_public", "unknown"]}
    },
    "allowed_retrieval_modes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["keyword", "embedding", "hybrid", "review_cache", "metadata"]}
    },
    "disallowed_sources": {"type": "array", "items": {"type": "string"}},
    "disabled_capabilities": {
      "type": "array",
      "items": {"type": "string", "enum": ["full_text_extraction", "mineru", "sci_hub", "final_idea_generation", "experiment_plan"]}
    },
    "claim_support_policy": {
      "type": "object",
      "required": ["rough_roi_only", "allow_strong_recommendation", "unknown_must_remain_unknown"],
      "additionalProperties": false,
      "properties": {
        "rough_roi_only": {"type": "boolean"},
        "allow_strong_recommendation": {"type": "boolean"},
        "unknown_must_remain_unknown": {"type": "boolean"}
      }
    },
    "evidence_defaults": {
      "type": "object",
      "required": ["rough_roi", "benchmark_burden", "compute_burden", "baseline_burden", "reviewer_risk"],
      "additionalProperties": false,
      "properties": {
        "rough_roi": {"type": "string", "enum": ["unknown", "weak", "insufficient_evidence"]},
        "benchmark_burden": {"type": "string", "enum": ["unknown", "weak", "insufficient_evidence"]},
        "compute_burden": {"type": "string", "enum": ["unknown", "weak", "insufficient_evidence"]},
        "baseline_burden": {"type": "string", "enum": ["unknown", "weak", "insufficient_evidence"]},
        "reviewer_risk": {"type": "string", "enum": ["unknown", "weak", "insufficient_evidence"]}
      }
    }
  }
}
