{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resmax://schemas/research_spec",
  "title": "ResearchSpec",
  "schema_version": "0.1.0",
  "type": "object",
  "required": ["schema_version", "state_id", "created_at", "input_hash", "parent_state_ids", "producer", "raw_intent", "problem_anchor", "search_profile", "target_venue", "timeline", "compute_budget", "team_size", "non_goals", "human_gates", "research_question", "objective", "scope", "roi_objectives", "unknowns", "decision_status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1.0"]},
    "state_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*:[0-9a-f]{8,64}$"},
    "created_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T"},
    "input_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "parent_state_ids": {"type": "array", "items": {"type": "string"}},
    "producer": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string"},
        "run_id": {"type": "string"}
      }
    },
    "raw_intent": {"type": "string", "minLength": 1},
    "problem_anchor": {"type": "string", "minLength": 1},
    "search_profile": {
      "type": "object",
      "required": ["core_topic", "entities", "desired_properties", "constraints", "non_goals"],
      "additionalProperties": false,
      "properties": {
        "core_topic": {"type": "string", "minLength": 1},
        "entities": {"type": "array", "items": {"type": "string"}},
        "desired_properties": {"type": "array", "items": {"type": "string"}},
        "constraints": {"type": "array", "items": {"type": "string"}},
        "non_goals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "target_venue": {"type": "string", "minLength": 1},
    "timeline": {"type": "string", "minLength": 1},
    "compute_budget": {"type": "string", "minLength": 1},
    "team_size": {"type": "string", "minLength": 1},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "human_gates": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "budget_policy": {
      "type": "object",
      "required": ["macro_max_candidates", "max_targeted_evidence_candidates", "evidence_expansion_requires_human_gate"],
      "additionalProperties": false,
      "properties": {
        "macro_max_candidates": {"type": "integer", "minimum": 1},
        "max_targeted_evidence_candidates": {"type": "integer", "minimum": 1},
        "evidence_expansion_requires_human_gate": {"type": "boolean"}
      }
    },
    "research_question": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "required": ["included_topics", "excluded_topics"],
      "additionalProperties": false,
      "properties": {
        "included_topics": {"type": "array", "items": {"type": "string"}},
        "excluded_topics": {"type": "array", "items": {"type": "string"}}
      }
    },
    "roi_objectives": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "unknowns": {"type": "array", "items": {"type": "string"}},
    "decision_status": {"type": "string", "enum": ["unknown", "pending", "promoted", "rejected", "needs_revision", "killed", "not_applicable"]}
  }
}
