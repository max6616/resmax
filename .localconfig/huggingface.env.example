# Hugging Face dataset package configuration
# Used by: .agents/skills/resmax-database/scripts/ensure_reviews_available.py
#
# Set this when raw review JSON is missing and the review package should be
# downloaded from a Hugging Face dataset repo.
export RESMAX_HF_DATASET_REPO=''

# Path inside the dataset repo that contains reviews_manifest.json,
# reviews_index.csv, checksums.sha256, and archives/.
export RESMAX_HF_REVIEWS_PATH='reviews'

# Usually "dataset"; keep the default unless the package is intentionally
# stored in another Hub repo type.
export RESMAX_HF_REPO_TYPE='dataset'
