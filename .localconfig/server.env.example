# Remote GPU server configuration
# Used by: resmax-embedding (build_cache_multigpu.py, encode_query.py)
#           resmax-survey  (embedding_filter.py — SSH fallback for query encoding)
#
# All values are non-secret runtime parameters. Set them to match your own
# GPU host. If you want to omit SSH and run everything locally, leave
# RESMAX_SSH_HOST empty and the scripts will only try the local code path.

# SSH host or ~/.ssh/config alias for the GPU server. Examples:
#   5090                       (if you have a Host alias in ~/.ssh/config)
#   user@192.168.1.100         (direct login)
#   gpu.example.com            (hostname)
export RESMAX_SSH_HOST=''

# Working directory on the remote server where encode_query.py / build scripts live.
# Must be writable by the SSH user.
export RESMAX_SSH_REMOTE_DIR='~/resmax_embedding_build'

# Absolute or ~-expanded path to the remote encode_query.py script.
# Defaults to <RESMAX_SSH_REMOTE_DIR>/scripts/encode_query.py if unset.
export RESMAX_SSH_REMOTE_SCRIPT='~/resmax_embedding_build/scripts/encode_query.py'

# Conda environment on the server that has torch / transformers / numpy.
export RESMAX_SSH_CONDA_ENV='llm'

# Conda init script on the server (miniconda3 or miniforge3 path).
# If your server has miniforge3 instead of miniconda3, switch to:
#   ~/miniforge3/etc/profile.d/conda.sh
export RESMAX_SSH_CONDA_INIT='~/miniconda3/etc/profile.d/conda.sh'
