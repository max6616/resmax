# === OS ===
.DS_Store
Thumbs.db

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Large data / cache (not suitable for git) ===
paper_database/
literature_research/
cache/
tmp/

# === Logs & temp ===
*.log
*.tmp

# === Agent local config ===
.claude/settings.local.json

# === Secrets (real credentials) ===
# Everything in .secrets/ is ignored EXCEPT templates and the README so
# new clones know what to populate.
.secrets/*
!.secrets/README.md
!.secrets/*.env.example

# === Local machine config (SSH hosts, paths, conda env names) ===
# Not credentials, but machine-specific; ship only the templates.
.localconfig/*
!.localconfig/README.md
!.localconfig/*.env.example

# === Archive (optional: uncomment if you want to exclude) ===
_archive_paperAnalysis/
_archive_resmax/
docs/
.codex/response-summary-log.md
